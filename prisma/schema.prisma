// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Institution {
  id       String          @id @default(uuid())
  name     String
  cnpj     String          @unique
  type     InstitutionType
  isActive Boolean         @default(true)

  students Student[]
  users    User[]
  teachers Teacher[]

  financialCategories   FinancialCategory[]
  financialAccounts     FinancialAccount[]
  financialTransactions FinancialTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("institutions")
}

model Student {
  id            String      @id @default(uuid())
  institutionId String
  institution   Institution @relation(fields: [institutionId], references: [id])

  // Dados Pessoais
  fullName   String
  cpf        String
  rg         String
  fatherName String?
  motherName String
  photoUrl   String?

  // Endereço
  state        String
  city         String
  neighborhood String
  street       String
  number       String
  parish       String?

  // Contato
  email            String
  phone            String
  emergencyContact String

  // Saúde e Restrições
  allergies           String? @db.Text
  dietaryRestrictions String? @db.Text

  enrollmentNumber String?

  user        User?

  enrollments Enrollment[]

  createdAt DateTime @default(now())
  updateAt  DateTime @updatedAt

  @@unique([cpf, institutionId])
  @@unique([email, institutionId])
  @@unique([enrollmentNumber, institutionId])
  @@map("students")
}

model User {
  id       String @id @default(uuid())
  name     String
  email    String @unique
  password String

  institutionId String
  institution   Institution @relation(fields: [institutionId], references: [id])

  teacherId     String?  @unique
  teacher       Teacher? @relation(fields: [teacherId], references: [id])

  studentId     String?  @unique
  student       Student? @relation(fields: [studentId], references: [id])

  auditLogs     GradeAuditLog[]
  roles         UserRole[]

  mustChangePassword Boolean @default(false)

  coordinatedCourses Course[] @relation("CourseCoordinator")

  createAt  DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model UserRole {
  id     String @id @default(uuid())
  userId String
  role   Role
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@map("user_roles")
}

model Teacher {
  id            String   @id @default(uuid())
  institutionId String
  institution   Institution @relation(fields: [institutionId], references: [id])

  // Dados Pessoais
  photoUrl      String?  // Será preenchido pelo Cloudinary
  title         Title?   // Tratamento (Sr, Sra...)
  fullName      String
  gender        Gender
  birthDate     DateTime @db.Date
  isActive      Boolean  @default(true) // Situação (Ativo/Inativo)

  // Documentos
  rg            String
  cpf           String
  ctpsNumber    String?  // Número da CTPS (opcional caso seja PJ)
  ctpsSeries    String?  // Série da CTPS (opcional)
  pis           String?  // PIS (opcional)

  // Contato
  phone         String
  email         String

  // Endereço
  state         String   // UF
  city          String
  neighborhood  String   // Bairro
  zipCode       String   // CEP
  street        String   // Logradouro
  number        String

  // Acadêmico
  qualification Qualification

  // Filiação
  fatherName    String?  // Opcional
  motherName    String

  user         User?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Regras Multi-tenant: O mesmo CPF/Email não pode repetir na MESMA instituição
  @@unique([cpf, institutionId])
  @@unique([email, institutionId])
  
  @@map("teachers")
  classSubjects ClassSubject[]
}

model Course {
  id              String         @id @default(uuid())
  institutionId   String
  name            String
  code            String
  modality        Modality
  level           Level
  workload        Int            // Carga horária total
  durationPeriods Int            // Duração em semestres/anos
  evaluationType  EvaluationType @default(BIMESTRAL) // Define quantos períodos avaliativos o curso possui
  isActive        Boolean        @default(true)

  coordinatorId   String?
  coordinator     User? @relation("CourseCoordinator", fields: [coordinatorId], references: [id])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  subjects        Subject[]
  classGroups     ClassGroup[]

  @@map("courses")
}

model Subject {
  id            String   @id @default(uuid())
  institutionId String
  courseId      String
  name          String
  code          String
  syllabus      String?  @db.Text // Ementa da disciplina
  workload      Int      // Carga horária
  credits       Int      @default(0)
  type          SubType  // Enum: MANDATORY, OPTIONAL, ELECTIVE
  
  course        Course   @relation(fields: [courseId], references: [id])

  classSubjects   ClassSubject[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("subjects")
}

model AcademicPeriod {
  id            String       @id @default(uuid())
  institutionId String
  name          String       // Ex: 2026.1, Ano Letivo 2026
  startDate     DateTime
  endDate       DateTime
  status        PeriodStatus // ENROLLMENT_OPEN, IN_PROGRESS, CLOSED

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  classGroups   ClassGroup[]  // Relacionamento com ClassGroup (1 para muitos)

  @@map("academic_periods")
}

model ClassGroup {
  id              String   @id @default(uuid())
  institutionId   String
  courseId        String
  periodId        String
  name            String   // Ex: 1º Ano A, ENG-Noturno
  shift           Shift    // MORNING, AFTERNOON, NIGHT, FULL_TIME
  isActive        Boolean  @default(true)

  course          Course         @relation(fields: [courseId], references: [id])
  period          AcademicPeriod @relation(fields: [periodId], references: [id])
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  classSubjects   ClassSubject[] 
  enrollments     Enrollment[]   

  @@map("class_groups")
}

model ClassSubject {
  id              String   @id @default(uuid())
  institutionId   String
  classGroupId    String
  subjectId       String
  teacherId       String?  // Relacionamento com o ID do Professor
  room            String?  // Ex: "Sala 204", "Laboratório B"
  totalSeats      Int      // Limite de alunos para esta matéria específica
  occupiedSeats   Int      @default(0) // Controlado automaticamente pelo backend depois

  diaries        ClassDiary[]

  classGroup      ClassGroup @relation(fields: [classGroupId], references: [id])
  subject         Subject    @relation(fields: [subjectId], references: [id])
  teacher         Teacher?   @relation(fields: [teacherId], references: [id])
  studentSubjects EnrollmentSubject[]
  
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@map("class_subjects")
}

model Enrollment {
  id              String   @id @default(uuid())
  institutionId   String
  studentId       String
  classGroupId    String
  enrollmentDate  DateTime @default(now())
  status          EnrolStatus @default(ACTIVE)

  student         Student      @relation(fields: [studentId], references: [id])
  classGroup      ClassGroup   @relation(fields: [classGroupId], references: [id])
  
  subjects        EnrollmentSubject[] // As disciplinas que ele vai cursar

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("enrollments")
}


model EnrollmentSubject {
  id              String   @id @default(uuid())
  institutionId   String
  enrollmentId    String
  classSubjectId  String
  status          SubjStatus @default(STUDYING)
  finalGrade      Float?
  finalAttendance Float?

  grades          Grade[]
  attendances     Attendance[]

  enrollment      Enrollment   @relation(fields: [enrollmentId], references: [id])
  classSubject    ClassSubject @relation(fields: [classSubjectId], references: [id])

  // grades          Grade[]   
  // attendances     Attendance[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("enrollment_subjects")
}

model ClassDiary {
  id             String       @id @default(uuid())
  institutionId  String
  classSubjectId String
  date           DateTime     @db.Date
  content        String       @db.Text // O que foi ensinado no dia

  classSubject   ClassSubject @relation(fields: [classSubjectId], references: [id])
  attendances    Attendance[]

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("class_diaries")
}

model Attendance {
  id                  String            @id @default(uuid())
  institutionId       String
  classDiaryId        String
  enrollmentSubjectId String
  isPresent           Boolean           @default(true)
  justification       String?           @db.Text // Caso falte e traga atestado

  classDiary          ClassDiary        @relation(fields: [classDiaryId], references: [id])
  enrollmentSubject   EnrollmentSubject @relation(fields: [enrollmentSubjectId], references: [id])

  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  // Garante que o mesmo aluno não tenha duas marcações no mesmo dia/diário
  @@unique([classDiaryId, enrollmentSubjectId]) 
  @@map("attendances")
}

// ==========================================
// MÓDULO FINANCEIRO
// ==========================================

model FinancialCategory {
  id            String               @id @default(uuid())
  institutionId String
  name          String
  description   String?
  type          TransactionType
  isActive      Boolean              @default(true)

  institution   Institution          @relation(fields: [institutionId], references: [id])
  transactions  FinancialTransaction[]

  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@map("financial_categories")
}

model FinancialAccount {
  id            String               @id @default(uuid())
  institutionId String
  name          String
  type          FinancialAccountType
  balance       Float                @default(0)
  description   String?
  isActive      Boolean              @default(true)

  institution   Institution          @relation(fields: [institutionId], references: [id])
  transactions  FinancialTransaction[]

  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@map("financial_accounts")
}

model FinancialTransaction {
  id            String            @id @default(uuid())
  institutionId String
  accountId     String
  categoryId    String
  type          TransactionType
  status        TransactionStatus @default(PENDING)
  amount        Float
  description   String
  dueDate       DateTime          @db.Date
  paymentDate   DateTime?         @db.Date
  reference     String?
  notes         String?           @db.Text

  institution   Institution       @relation(fields: [institutionId], references: [id])
  account       FinancialAccount  @relation(fields: [accountId], references: [id])
  category      FinancialCategory @relation(fields: [categoryId], references: [id])

  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@map("financial_transactions")
}

// ==========================================
// MÓDULO DE NOTAS E AUDITORIA (COMPROVANTE)
// ==========================================

model Grade {
  id                  String            @id @default(uuid())
  institutionId       String
  enrollmentSubjectId String
  name                String            // Ex: "AV1", "Trabalho Final"
  value               Float             // O valor da nota em si
  weight              Float             @default(1.0) // Peso da nota na média
  date                DateTime          @db.Date
  period              Int?              // Período avaliativo: 1, 2, 3 ou 4 (bimestre/trimestre/semestre)

  enrollmentSubject   EnrollmentSubject @relation(fields: [enrollmentSubjectId], references: [id])
  auditLogs           GradeAuditLog[]

  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@map("grades")
}

model GradeAuditLog {
  id            String      @id @default(uuid())
  institutionId String
  gradeId       String?     // Pode ficar null se a nota for deletada
  userId        String      // O ID do usuário logado (Professor ou Diretor) que fez a ação
  action        AuditAction // CREATED, UPDATED, DELETED
  oldValue      Float?      // Nota antes da alteração
  newValue      Float?      // Nota depois da alteração
  reason        String?     @db.Text // Justificativa opcional para alterar a nota

  grade         Grade?      @relation(fields: [gradeId], references: [id], onDelete: SetNull)
  user          User        @relation(fields: [userId], references: [id])

  createdAt     DateTime    @default(now())

  @@map("grade_audit_logs")
}

enum InstitutionType {
  SCHOOL
  UNIVERSITY
  COURSE
}

enum Title {
  SR
  SRA
  PROF
  DR
  DRA
}

enum Gender {
  MALE
  FEMALE
}

enum Qualification {
  TITULATION       // Titulação
  GRADUATION       // Graduação
  SPECIALIZATION   // Especialização
  MASTER           // Mestrado
  DOCTORATE        // Doutorado
}

enum Modality {
  PRESENTIAL
  EAD
  HYBRID
}

enum Level {
  BASIC
  HIGH_SCHOOL
  TECHNICAL
  GRADUATION
  POSTGRADUATION
}

enum SubType {
  MANDATORY
  OPTIONAL
  ELECTIVE
}

enum PeriodStatus {
  ENROLLMENT_OPEN
  IN_PROGRESS
  CLOSED
}

enum Shift {
  MORNING
  AFTERNOON
  NIGHT
  FULL_TIME
}

enum EnrolStatus {
  ACTIVE
  SUSPENDED
  CANCELLED
  COMPLETED
}

enum SubjStatus {
  STUDYING
  APPROVED
  FAILED
  FAILED_BY_ABSENCE
}

enum Role {
  ADMIN
  COORDINATOR
  TEACHER
  STUDENT
}

enum AuditAction {
  CREATED
  UPDATED
  DELETED
}

enum EvaluationType {
  BIMESTRAL   // 4 períodos (padrão escolas brasileiras)
  TRIMESTRAL  // 3 períodos
  SEMESTRAL   // 2 períodos (padrão faculdades/universidades)
  ANUAL       // 1 período
}

enum FinancialAccountType {
  CHECKING  // Conta Corrente
  SAVINGS   // Conta Poupança
  CASH      // Caixa físico
  CREDIT    // Cartão de Crédito
  OTHER
}

enum TransactionType {
  INCOME   // Receita / Entrada
  EXPENSE  // Despesa / Saída
}

enum TransactionStatus {
  PENDING    // Pendente (não impacta saldo)
  CONFIRMED  // Confirmado (impacta saldo)
  CANCELLED  // Cancelado (reverte saldo se era CONFIRMED)
}