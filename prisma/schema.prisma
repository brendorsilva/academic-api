// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Institution {
  id       String          @id @default(uuid())
  name     String
  cnpj     String          @unique
  type     InstitutionType
  isActive Boolean         @default(true)

  students Student[]
  users    User[]
  teachers Teacher[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("institutions")
}

model Student {
  id            String      @id @default(uuid())
  institutionId String
  institution   Institution @relation(fields: [institutionId], references: [id])

  // Dados Pessoais
  fullName   String
  cpf        String
  rg         String
  fatherName String?
  motherName String
  photoUrl   String?

  // Endereço
  state        String
  city         String
  neighborhood String
  street       String
  number       String
  parish       String?

  // Contato
  email            String
  phone            String
  emergencyContact String

  // Saúde e Restrições
  allergies           String? @db.Text
  dietaryRestrictions String? @db.Text

  enrollmentNumber String?

  createdAt DateTime @default(now())
  updateAt  DateTime @updatedAt

  @@unique([cpf, institutionId])
  @@unique([email, institutionId])
  @@unique([enrollmentNumber, institutionId])
  @@map("students")
}

model User {
  id       String @id @default(uuid())
  name     String
  email    String @unique
  password String

  institutionId String
  institution   Institution @relation(fields: [institutionId], references: [id])

  createAt  DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Teacher {
  id            String   @id @default(uuid())
  institutionId String
  institution   Institution @relation(fields: [institutionId], references: [id])

  // Dados Pessoais
  photoUrl      String?  // Será preenchido pelo Cloudinary
  title         Title?   // Tratamento (Sr, Sra...)
  fullName      String
  gender        Gender
  birthDate     DateTime @db.Date
  isActive      Boolean  @default(true) // Situação (Ativo/Inativo)

  // Documentos
  rg            String
  cpf           String
  ctpsNumber    String?  // Número da CTPS (opcional caso seja PJ)
  ctpsSeries    String?  // Série da CTPS (opcional)
  pis           String?  // PIS (opcional)

  // Contato
  phone         String
  email         String

  // Endereço
  state         String   // UF
  city          String
  neighborhood  String   // Bairro
  zipCode       String   // CEP
  street        String   // Logradouro
  number        String

  // Acadêmico
  qualification Qualification

  // Filiação
  fatherName    String?  // Opcional
  motherName    String

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Regras Multi-tenant: O mesmo CPF/Email não pode repetir na MESMA instituição
  @@unique([cpf, institutionId])
  @@unique([email, institutionId])
  
  @@map("teachers")
}

model Course {
  id              String   @id @default(uuid())
  institutionId   String
  name            String
  code            String
  modality        Modality
  level           Level
  workload        Int      // Carga horária total
  durationPeriods Int      // Duração em semestres/anos
  isActive        Boolean  @default(true)
  coordinatorId   String? 

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  subjects        Subject[]
  classGroups     ClassGroup[]

  @@map("courses")
}

model Subject {
  id            String   @id @default(uuid())
  institutionId String
  courseId      String
  name          String
  code          String
  syllabus      String?  @db.Text // Ementa da disciplina
  workload      Int      // Carga horária
  credits       Int      @default(0)
  type          SubType  // Enum: MANDATORY, OPTIONAL, ELECTIVE
  
  course        Course   @relation(fields: [courseId], references: [id])
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("subjects")
}

model AcademicPeriod {
  id            String       @id @default(uuid())
  institutionId String
  name          String       // Ex: 2026.1, Ano Letivo 2026
  startDate     DateTime
  endDate       DateTime
  status        PeriodStatus // ENROLLMENT_OPEN, IN_PROGRESS, CLOSED

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  classGroups   ClassGroup[]  // Relacionamento com ClassGroup (1 para muitos)

  @@map("academic_periods")
}

model ClassGroup {
  id              String   @id @default(uuid())
  institutionId   String
  courseId        String
  periodId        String
  name            String   // Ex: 1º Ano A, ENG-Noturno
  shift           Shift    // MORNING, AFTERNOON, NIGHT, FULL_TIME
  isActive        Boolean  @default(true)

  course          Course         @relation(fields: [courseId], references: [id])
  period          AcademicPeriod @relation(fields: [periodId], references: [id])
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // classSubjects   ClassSubject[] 
  // enrollments     Enrollment[]   

  @@map("class_groups")
}

enum InstitutionType {
  SCHOOL
  UNIVERSITY
  COURSE
}

enum Title {
  SR
  SRA
  PROF
  DR
  DRA
}

enum Gender {
  MALE
  FEMALE
}

enum Qualification {
  TITULATION       // Titulação
  GRADUATION       // Graduação
  SPECIALIZATION   // Especialização
  MASTER           // Mestrado
  DOCTORATE        // Doutorado
}

enum Modality {
  PRESENTIAL
  EAD
  HYBRID
}

enum Level {
  BASIC
  HIGH_SCHOOL
  TECHNICAL
  GRADUATION
  POSTGRADUATION
}

enum SubType {
  MANDATORY
  OPTIONAL
  ELECTIVE
}

enum PeriodStatus {
  ENROLLMENT_OPEN
  IN_PROGRESS
  CLOSED
}

enum Shift {
  MORNING
  AFTERNOON
  NIGHT
  FULL_TIME
}

enum EnrolStatus {
  ACTIVE
  SUSPENDED
  CANCELLED
  COMPLETED
}

enum SubjStatus {
  STUDYING
  APPROVED
  FAILED
  FAILED_BY_ABSENCE
}